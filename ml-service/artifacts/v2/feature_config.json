{
  "features": [
    "Account_Age_Days",
    "Daily_Usage_Mins",
    "login_freq_enc",
    "ticket_sentiment",
    "days_since_last_login",
    "core_feature_usage_percentage"
  ],
  "feature_schema": [
    {
      "key": "Account_Age_Days",
      "request_field": "account_age_days",
      "dtype": "int",
      "min_value": 0,
      "max_value": 3650,
      "whatif_default": null
    },
    {
      "key": "Daily_Usage_Mins",
      "request_field": "daily_usage_mins",
      "dtype": "int",
      "min_value": 0,
      "max_value": 1440,
      "whatif_default": 0
    },
    {
      "key": "login_freq_enc",
      "request_field": "login_frequency",
      "dtype": "int",
      "min_value": 0,
      "max_value": 2,
      "whatif_default": null
    },
    {
      "key": "ticket_sentiment",
      "request_field": "last_support_ticket",
      "dtype": "float",
      "min_value": -1.0,
      "max_value": 1.0,
      "whatif_default": null
    },
    {
      "key": "days_since_last_login",
      "request_field": "days_since_last_login",
      "dtype": "int",
      "min_value": 0,
      "max_value": 3650,
      "whatif_default": 0
    },
    {
      "key": "core_feature_usage_percentage",
      "request_field": "core_feature_usage_percentage",
      "dtype": "float",
      "min_value": 0.0,
      "max_value": 100.0,
      "whatif_default": 100.0
    }
  ],
  "login_freq_encoding": {
    "Rarely": 0,
    "Weekly": 1,
    "Daily": 2
  },
  "default_sentiment": 0.0,
  "threshold": 0.5
}